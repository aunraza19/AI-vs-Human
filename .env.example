LIVEKIT_URL=ws://localhost:7880
LIVEKIT_SERVER_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace_with_32_char_secret_min
GOOGLE_API_KEY=your_google_api_key

AGENT_NAME=debate-agent
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Puck
MAX_HUMAN_TURNS=8

# Optional for Docker Compose LiveKit advertise address.
# For same-machine browser testing, keep 127.0.0.1.
# LIVEKIT_NODE_IP=127.0.0.1

# If running API/worker directly on your host (without Docker),
# set LIVEKIT_SERVER_URL=ws://127.0.0.1:7880 instead.
